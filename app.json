{
  "expo": {
    "name": "Talentra",
    "slug": "talentra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/talentra-logo.png",
    "scheme": "talentra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.talentra.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/images/talentra-logo.png",
        "backgroundImage": "./assets/images/talentra-logo.png",
        "monochromeImage": "./assets/images/talentra-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/talentra-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ded54d47-a9e7-4428-9b90-2ca42e107c71"
      }
    }
  }
}
